+// Tests for the annotation allowlist (crashkit patch).
+// These run fully in-memory via StringFile — no device required.
+
+TEST(MinidumpModuleCrashpadInfoWriter, AllowlistFiltersSimpleAnnotations) {
+  // Module has two simple-map annotations: "allowed_key" and "pii_key".
+  // The allowlist only permits "allowed_key"; "pii_key" must be absent.
+  static constexpr char kAllowedKey[] = "allowed_key";
+  static constexpr char kAllowedValue[] = "safe_value";
+  static constexpr char kPiiKey[] = "pii_key";
+  static constexpr char kPiiValue[] = "secret";
+
+  TestModuleSnapshot module_snapshot;
+  std::map<std::string, std::string> simple_map;
+  simple_map[kAllowedKey] = kAllowedValue;
+  simple_map[kPiiKey] = kPiiValue;
+  module_snapshot.SetAnnotationsSimpleMap(simple_map);
+
+  const std::set<std::string> allowed_annotations = {kAllowedKey};
+
+  auto module_list_writer =
+      std::make_unique<MinidumpModuleCrashpadInfoListWriter>();
+  std::vector<const ModuleSnapshot*> snapshots = {&module_snapshot};
+  module_list_writer->InitializeFromSnapshot(snapshots, &allowed_annotations);
+  EXPECT_TRUE(module_list_writer->IsUseful());
+
+  StringFile string_file;
+  ASSERT_TRUE(module_list_writer->WriteEverything(&string_file));
+
+  const MinidumpModuleCrashpadInfoList* module_list =
+      MinidumpModuleCrashpadInfoListAtStart(string_file.string(), 1);
+  ASSERT_TRUE(module_list);
+
+  const MinidumpModuleCrashpadInfo* module =
+      MinidumpWritableAtLocationDescriptor<MinidumpModuleCrashpadInfo>(
+          string_file.string(), module_list->modules[0].location);
+  ASSERT_TRUE(module);
+
+  const MinidumpSimpleStringDictionary* written_annotations =
+      MinidumpWritableAtLocationDescriptor<MinidumpSimpleStringDictionary>(
+          string_file.string(), module->simple_annotations);
+  ASSERT_TRUE(written_annotations);
+
+  // Exactly one annotation must survive: the allowed one.
+  ASSERT_EQ(written_annotations->count, 1u);
+  EXPECT_EQ(MinidumpUTF8StringAtRVAAsString(string_file.string(),
+                                            written_annotations->entries[0].key),
+            kAllowedKey);
+  EXPECT_EQ(MinidumpUTF8StringAtRVAAsString(
+                string_file.string(), written_annotations->entries[0].value),
+            kAllowedValue);
+}
+
+TEST(MinidumpModuleCrashpadInfoWriter, AllowlistFiltersAnnotationObjects) {
+  // Module has two annotation objects: "allowed_annotation" and "guid".
+  // The allowlist only permits "allowed_annotation"; "guid" must be absent.
+  const AnnotationSnapshot allowed_ann(
+      "allowed_annotation", 1, {'o', 'k'});
+  const AnnotationSnapshot pii_ann(
+      "guid", 1, {'d', 'e', 'a', 'd', 'b', 'e', 'e', 'f'});
+
+  TestModuleSnapshot module_snapshot;
+  module_snapshot.SetAnnotationObjects({allowed_ann, pii_ann});
+
+  const std::set<std::string> allowed_annotations = {"allowed_annotation"};
+
+  auto module_list_writer =
+      std::make_unique<MinidumpModuleCrashpadInfoListWriter>();
+  std::vector<const ModuleSnapshot*> snapshots = {&module_snapshot};
+  module_list_writer->InitializeFromSnapshot(snapshots, &allowed_annotations);
+  EXPECT_TRUE(module_list_writer->IsUseful());
+
+  StringFile string_file;
+  ASSERT_TRUE(module_list_writer->WriteEverything(&string_file));
+
+  const MinidumpModuleCrashpadInfoList* module_list =
+      MinidumpModuleCrashpadInfoListAtStart(string_file.string(), 1);
+  ASSERT_TRUE(module_list);
+
+  const MinidumpModuleCrashpadInfo* module =
+      MinidumpWritableAtLocationDescriptor<MinidumpModuleCrashpadInfo>(
+          string_file.string(), module_list->modules[0].location);
+  ASSERT_TRUE(module);
+
+  const MinidumpAnnotationList* written_objects =
+      MinidumpWritableAtLocationDescriptor<MinidumpAnnotationList>(
+          string_file.string(), module->annotation_objects);
+  ASSERT_TRUE(written_objects);
+
+  // Exactly one object must survive: the allowed one.
+  ASSERT_EQ(written_objects->count, 1u);
+  EXPECT_EQ(
+      MinidumpUTF8StringAtRVAAsString(string_file.string(),
+                                      written_objects->objects[0].name),
+      allowed_ann.name);
+}
+
+TEST(MinidumpModuleCrashpadInfoWriter, AllowlistEmptyDropsModule) {
+  // When the allowlist is non-null but empty, every annotation is filtered out
+  // and the module produces no useful data (not written at all).
+  TestModuleSnapshot module_snapshot;
+  std::map<std::string, std::string> simple_map;
+  simple_map["some_key"] = "some_value";
+  module_snapshot.SetAnnotationsSimpleMap(simple_map);
+  module_snapshot.SetAnnotationObjects(
+      {AnnotationSnapshot("guid", 1, {'x'})});
+
+  const std::set<std::string> allowed_annotations;  // empty
+
+  auto module_list_writer =
+      std::make_unique<MinidumpModuleCrashpadInfoListWriter>();
+  std::vector<const ModuleSnapshot*> snapshots = {&module_snapshot};
+  module_list_writer->InitializeFromSnapshot(snapshots, &allowed_annotations);
+
+  // No module carries useful data after filtering.
+  EXPECT_FALSE(module_list_writer->IsUseful());
+}
