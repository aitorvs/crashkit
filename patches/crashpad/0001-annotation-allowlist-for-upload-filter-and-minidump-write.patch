+  const AnnotationSnapshot ann("variations", 1, {'v'});
+
+  TestModuleSnapshot module_snapshot;
+  std::map<std::string, std::string> simple_map;
+  simple_map[kKey] = kValue;
+  module_snapshot.SetAnnotationsSimpleMap(simple_map);
+  module_snapshot.SetAnnotationObjects({ann});
+
+  auto module_list_writer =
+      std::make_unique<MinidumpModuleCrashpadInfoListWriter>();
+  std::vector<const ModuleSnapshot*> snapshots = {&module_snapshot};
+  module_list_writer->InitializeFromSnapshot(snapshots, nullptr);
+  EXPECT_TRUE(module_list_writer->IsUseful());
+
+  StringFile string_file;
+  ASSERT_TRUE(module_list_writer->WriteEverything(&string_file));
+
+  const MinidumpModuleCrashpadInfoList* module_list =
+      MinidumpModuleCrashpadInfoListAtStart(string_file.string(), 1);
+  ASSERT_TRUE(module_list);
+
+  const MinidumpModuleCrashpadInfo* module =
+      MinidumpWritableAtLocationDescriptor<MinidumpModuleCrashpadInfo>(
+          string_file.string(), module_list->modules[0].location);
+  ASSERT_TRUE(module);
+
+  // Both annotation types must be present when no filter is applied.
+  const MinidumpSimpleStringDictionary* written_simple =
+      MinidumpWritableAtLocationDescriptor<MinidumpSimpleStringDictionary>(
+          string_file.string(), module->simple_annotations);
+  ASSERT_TRUE(written_simple);
+  EXPECT_EQ(written_simple->count, 1u);
+
+  const MinidumpAnnotationList* written_objects =
+      MinidumpWritableAtLocationDescriptor<MinidumpAnnotationList>(
+          string_file.string(), module->annotation_objects);
+  ASSERT_TRUE(written_objects);
+  EXPECT_EQ(written_objects->count, 1u);
+}
