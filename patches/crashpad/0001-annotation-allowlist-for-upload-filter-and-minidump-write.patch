+// Tests for the annotation allowlist (crashkit patch).
+// These run fully in-memory via StringFile — no device required.
+
+TEST(MinidumpCrashpadInfoWriter, AllowlistFiltersModuleAnnotations) {
+  // Process snapshot has one module with two annotations: "crash_key" (allowed)
+  // and "guid" (blocked). The allowlist must strip "guid" from the minidump.
+  static constexpr char kAllowedKey[] = "crash_key";
+  static constexpr char kAllowedValue[] = "OOM";
+  static constexpr char kPiiKey[] = "guid";
+  static constexpr char kPiiValue[] = "some-uuid";
+
+  auto process_snapshot = std::make_unique<TestProcessSnapshot>();
+
+  auto module_snapshot = std::make_unique<TestModuleSnapshot>();
+  std::map<std::string, std::string> simple_map;
+  simple_map[kAllowedKey] = kAllowedValue;
+  simple_map[kPiiKey] = kPiiValue;
+  module_snapshot->SetAnnotationsSimpleMap(simple_map);
+  process_snapshot->AddModule(std::move(module_snapshot));
+
+  const std::set<std::string> allowed_annotations = {kAllowedKey};
+
+  auto info_writer = std::make_unique<MinidumpCrashpadInfoWriter>();
+  info_writer->InitializeFromSnapshot(process_snapshot.get(),
+                                      &allowed_annotations);
+  EXPECT_TRUE(info_writer->IsUseful());
+
+  MinidumpFileWriter minidump_file_writer;
+  ASSERT_TRUE(minidump_file_writer.AddStream(std::move(info_writer)));
+
+  StringFile string_file;
+  ASSERT_TRUE(minidump_file_writer.WriteEverything(&string_file));
+
+  const MinidumpCrashpadInfo* info = nullptr;
+  const MinidumpSimpleStringDictionary* process_simple_annotations = nullptr;
+  const MinidumpModuleCrashpadInfoList* module_list = nullptr;
+  ASSERT_NO_FATAL_FAILURE(GetCrashpadInfoStream(
+      string_file.string(), &info, &process_simple_annotations, &module_list));
+
+  // The module list must be present with one entry.
+  ASSERT_TRUE(module_list);
+  ASSERT_EQ(module_list->count, 1u);
+
+  const MinidumpModuleCrashpadInfo* module =
+      MinidumpWritableAtLocationDescriptor<MinidumpModuleCrashpadInfo>(
+          string_file.string(), module_list->modules[0].location);
+  ASSERT_TRUE(module);
+
+  const MinidumpSimpleStringDictionary* written_module_annotations =
+      MinidumpWritableAtLocationDescriptor<MinidumpSimpleStringDictionary>(
+          string_file.string(), module->simple_annotations);
+  ASSERT_TRUE(written_module_annotations);
+
+  // Only "crash_key" must survive.
+  ASSERT_EQ(written_module_annotations->count, 1u);
+  EXPECT_EQ(MinidumpUTF8StringAtRVAAsString(
+                string_file.string(),
+                written_module_annotations->entries[0].key),
+            kAllowedKey);
+  EXPECT_EQ(MinidumpUTF8StringAtRVAAsString(
+                string_file.string(),
+                written_module_annotations->entries[0].value),
+            kAllowedValue);
+}
+
+TEST(MinidumpCrashpadInfoWriter, AllowlistEmptyFiltersAllModuleAnnotations) {
+  // With an empty allowlist every annotation is stripped; the module becomes
+  // useless and must not appear in the minidump at all.
+  auto process_snapshot = std::make_unique<TestProcessSnapshot>();
+
+  auto module_snapshot = std::make_unique<TestModuleSnapshot>();
+  std::map<std::string, std::string> simple_map;
+  simple_map["guid"] = "some-uuid";
+  simple_map["variations"] = "abc123";
+  module_snapshot->SetAnnotationsSimpleMap(simple_map);
+  module_snapshot->SetAnnotationObjects(
+      {AnnotationSnapshot("gpu-generation", 1, {'0'})});
+  process_snapshot->AddModule(std::move(module_snapshot));
+
+  const std::set<std::string> allowed_annotations;  // empty
+
+  auto info_writer = std::make_unique<MinidumpCrashpadInfoWriter>();
+  info_writer->InitializeFromSnapshot(process_snapshot.get(),
+                                      &allowed_annotations);
+
+  // No module carries useful data — IsUseful() should be false (nothing to
+  // write into the crashpad info stream beyond the bare struct).
+  EXPECT_FALSE(info_writer->IsUseful());
+}
+
 }  // namespace
 }  // namespace test
 }  // namespace crashpad
